{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile & Run",
            "type": "shell",
            "command": "C:\\MinGW\\bin\\g++",
            "args": [
                "-std=c++17",
                "-O2",
                "-Wall",
                "solution.cpp",
                "-o",
                "solution.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "Run & Show Output",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                ".\\solution.exe; Write-Host '---OUTPUT---'; Get-Content output.txt"
            ],
            "dependsOn": ["Compile & Run"],
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        }
    ]
}
